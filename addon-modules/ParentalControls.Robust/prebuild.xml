<Project
    name="ParentalControlsRobustModule"
    path="addon-modules/ParentalControls.Robust"
    type="Library"
    version="0.1.0-$Rev$"
    frameworkVersion="net8_0">

<PropertyGroup>
  <TargetFramework>net8.0</TargetFramework>
  <AssemblyName>ParentalControlsRobust</AssemblyName>
  <RootNamespace>OpenSim.Services.ParentalControls</RootNamespace>
  <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
</PropertyGroup>

  <Configuration name="Release">
    <Options>
      <OutputPath>../../bin/</OutputPath>
       <SuppressWarnings>2002</SuppressWarnings>
    </Options>
  </Configuration>

  <ReferencePath>../../bin/</ReferencePath>

  <Reference name="OpenSim.Services.Interfaces"/>
  <Reference name="OpenSim.Services.Base"/>
  <Reference name="OpenSim.Services.Connectors"/>
  <Reference name="OpenSim.Services.LLLoginService"/>
  <Reference name="OpenSim.Server.Base"/>
  <Reference name="OpenSim.Framework"/>
  <Reference name="OpenMetaverse"/>
  <Reference name="OpenMetaverseTypes"/>
  <Reference name="OpenMetaverse.StructuredData"/>
  <Reference name="log4net"/>
  <Reference name="MySql.Data"/>
  <Reference name="Nini"/>

  <Files>
    <Match pattern="*.cs" recurse="true" />
    <Exclude name="obj/**" />
    <Exclude name="bin/**" />
  </Files>

</Project>

